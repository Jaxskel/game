{
  "name": "global-conflict-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first PWA giving the public a clear, safety-gated worldwide view of conflicts, diplomacy, humanitarian developments, and official addresses from attributed public sources.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "maplibre-gl": "5.6.1",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "20.19.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.30.1",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.3",
    "vitest": "4.1.10"
  }
}
