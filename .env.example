# Global Conflict Monitor — environment template.
# Copy to .env.local and fill in. Placeholders only — never commit real values.
#
# The app runs fully in DEMO/FIXTURE mode with NO credentials: every live
# provider integration is behind an interface and falls back to labeled
# fixtures. See docs/HANDOFF.md for which integrations are BLOCKED pending
# credentials/licenses.

# --- Live source adapters (all optional; absent = fixture mode) -------------
# ACLED — requires a valid license permitting this use. Do not enable without
# confirming license terms.
ACLED_API_KEY=
ACLED_EMAIL=

# YouTube Data API — used only against an editor-approved allowlist of
# official channels for address live/replay discovery.
YOUTUBE_API_KEY=

# Licensed news API supplied by the operator (interface: lib/sources/types.ts)
NEWS_API_KEY=

# --- Infrastructure (reference deployment; optional locally) ----------------
# PostgreSQL + PostGIS connection string (production source of truth).
DATABASE_URL=

# Redis for cache/queues (production).
REDIS_URL=

# S3-compatible object storage for retention-bounded permitted source records.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- App ---------------------------------------------------------------------
# Force demo/fixture mode even if credentials are present.
DEMO_MODE=1

# Minimum kinetic-incident safety delay in minutes (server-side floor: 60).
SAFETY_DELAY_MINUTES=60
